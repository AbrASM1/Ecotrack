{
    "annotations": { "list": [] },
    "editable": true,
    "graphTooltip": 1,
    "schemaVersion": 39,
    "tags": ["ecotrack", "iot", "security"],
    "time": { "from": "now-1h", "to": "now" },
    "timezone": "browser",
    "title": "ECOTRACK Overview",
    "uid": "ecotrack-overview",
    "version": 2,
    "refresh": "10s",
    "templating": { "list": [] },
    "panels": [
      { "id": 100, "type": "row", "title": "IoT", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
      {
        "id": 1, "title": "IoT readings / sec (global)", "type": "stat",
        "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "green", "value": 1 } ] } } },
        "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
        "targets": [ { "refId": "A", "expr": "sum(rate(iot_readings_sent_total[5m]))", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 2, "title": "Active devices", "type": "stat",
        "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } },
        "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
        "targets": [ { "refId": "A", "expr": "iot_devices_active", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 3, "title": "IoT POST errors (5m)", "type": "stat",
        "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
        "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
        "targets": [ { "refId": "A", "expr": "sum(increase(iot_post_errors_total[5m]))", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 4, "title": "IoT POST latency p95", "type": "stat",
        "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "s", "decimals": 3, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 } ] } } },
        "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
        "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(iot_post_duration_seconds_bucket[5m])) by (le))", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 5, "title": "Readings rate per device", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
        "targets": [ { "refId": "A", "expr": "rate(iot_readings_sent_total[5m])", "legendFormat": "{{device_id}}", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 6, "title": "Last value per device", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 1 } } },
        "targets": [ { "refId": "A", "expr": "iot_last_value", "legendFormat": "{{device_id}}", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 7, "title": "DB ingestion rate (commits/s)", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
        "targets": [ { "refId": "A", "expr": "rate(pg_stat_database_xact_commit{datname=\"ecotrack\"}[5m])", "legendFormat": "commits/s", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 8, "title": "EcoTrack DB size", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
        "targets": [ { "refId": "A", "expr": "pg_database_size_bytes{datname=\"ecotrack\"}", "legendFormat": "db size", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      { "id": 200, "type": "row", "title": "Disponibilite / Downtime", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 } },
      {
        "id": 10, "title": "Services UP", "type": "stat",
        "gridPos": { "h": 5, "w": 6, "x": 0, "y": 23 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 7 }, { "color": "green", "value": 8 } ] } } },
        "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
        "targets": [ { "refId": "A", "expr": "sum(up)", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 11, "title": "Targets DOWN", "type": "stat",
        "gridPos": { "h": 5, "w": 6, "x": 6, "y": 23 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
        "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
        "targets": [ { "refId": "A", "expr": "count(up == 0) or vector(0)", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 12, "title": "API availability 1h (%)", "type": "stat",
        "gridPos": { "h": 5, "w": 6, "x": 12, "y": 23 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 } ] } } },
        "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
        "targets": [ { "refId": "A", "expr": "avg_over_time(iot_api_up[1h]) * 100", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 13, "title": "PostgreSQL uptime", "type": "stat",
        "gridPos": { "h": 5, "w": 6, "x": 18, "y": 23 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 60 } ] } } },
        "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
        "targets": [ { "refId": "A", "expr": "time() - pg_postmaster_start_time_seconds", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 14, "title": "Service UP/DOWN timeline (per job)", "type": "state-timeline",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "max": 1, "min": 0 } },
        "options": { "showValue": "never", "mergeValues": true },
        "targets": [ { "refId": "A", "expr": "up", "legendFormat": "{{job}}", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      { "id": 300, "type": "row", "title": "WAF / Securite", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 } },
      {
        "id": 20, "title": "HTTP req/s (WAF)", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
        "targets": [ { "refId": "A", "expr": "rate(nginx_http_requests_total[5m])", "legendFormat": "req/s", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 21, "title": "Nginx connections", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
        "targets": [
          { "refId": "A", "expr": "nginx_connections_active", "legendFormat": "active", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } },
          { "refId": "B", "expr": "nginx_connections_reading", "legendFormat": "reading", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } },
          { "refId": "C", "expr": "nginx_connections_writing", "legendFormat": "writing", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } },
          { "refId": "D", "expr": "nginx_connections_waiting", "legendFormat": "waiting", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } }
        ]
      },
      { "id": 400, "type": "row", "title": "Ressources conteneurs", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 } },
      {
        "id": 30, "title": "Memoire par conteneur", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
        "targets": [ { "refId": "A", "expr": "sum by (name) (container_memory_usage_bytes{name=~\"ecotrack-.*\"})", "legendFormat": "{{name}}", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 31, "title": "CPU par conteneur", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
        "targets": [ { "refId": "A", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"ecotrack-.*\"}[5m]))", "legendFormat": "{{name}}", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } } ]
      },
      {
        "id": 32, "title": "Host load1 / mem available", "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 54 },
        "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" },
        "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "mem available (MiB)" }, "properties": [ { "id": "unit", "value": "decmbytes" } ] } ] },
        "targets": [
          { "refId": "A", "expr": "node_load1", "legendFormat": "load1", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } },
          { "refId": "B", "expr": "node_memory_MemAvailable_bytes / 1024 / 1024", "legendFormat": "mem available (MiB)", "datasource": { "type": "prometheus", "uid": "ECOTRACK_PROM" } }
        ]
      }
    ]
  }
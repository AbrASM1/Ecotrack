alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"ECOTRACK ICMP echo request inbound"; itype:8; classtype:misc-activity; sid:1000001; rev:1;)
drop http any any -> any any (msg:"ECOTRACK SQLi UNION SELECT in HTTP request"; flow:to_server,established; http.uri; content:"union"; nocase; content:"select"; nocase; distance:0; classtype:web-application-attack; sid:1000002; rev:1;)
drop http any any -> any any (msg:"ECOTRACK SQL injection scanner sqlmap user-agent"; flow:to_server,established; http.user_agent; content:"sqlmap"; nocase; classtype:web-application-attack; sid:1000003; rev:1;)
drop http any any -> any any (msg:"ECOTRACK directory traversal attempt in URI"; flow:to_server,established; http.uri; content:"../"; classtype:web-application-attack; sid:1000004; rev:1;)
alert tcp any any -> any 3000 (msg:"ECOTRACK direct API port access bypassing WAF"; flow:to_server; flags:S; classtype:policy-violation; sid:1000005; rev:1;)
drop http any any -> any any (msg:"ECOTRACK XSS attempt in URI"; flow:to_server,established; http.uri; pcre:"/(%3[Cc]script|onerror|onload|javascript:)/i"; classtype:web-application-attack; sid:1000006; rev:1;)
drop http any any -> any any (msg:"ECOTRACK web scanner user-agent"; flow:to_server,established; http.user_agent; pcre:"/(nikto|nmap|masscan|nessus|dirbuster|gobuster|wpscan|nuclei|acunetix|zgrab|fimap|wfuzz|hydra)/i"; classtype:web-application-attack; sid:1000007; rev:1;)
drop http any any -> any any (msg:"ECOTRACK command injection in URI"; flow:to_server,established; http.uri; pcre:"/(%3B|%7C)(cat|ls|id|whoami|uname|wget|curl|nc|bash|sh|ping)/i"; classtype:web-application-attack; sid:1000008; rev:1;)
drop http any any -> any any (msg:"ECOTRACK sensitive file access attempt"; flow:to_server,established; http.uri; pcre:"/(etc\/passwd|etc\/shadow|boot\.ini|win\.ini)/i"; classtype:web-application-attack; sid:1000009; rev:1;)
alert tcp any any -> $HOME_NET any (msg:"ECOTRACK TCP SYN port scan detected"; flags:S; flow:to_server; threshold:type both, track by_src, count 30, seconds 5; classtype:attempted-recon; sid:1000011; rev:1;)
